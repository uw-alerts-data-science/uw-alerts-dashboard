# Flask app
OPENAI_API_KEY='your-openai-key-here'
GOOGLE_MAPS_API_KEY='your-google-maps-key-here'
MAPBOX_API_KEY='your-mapbox-key-here'

# Scraper service
ANTHROPIC_API_KEY='your-anthropic-key-here'
DATABASE_URL='postgres://postgres:postgres@localhost:5432/uw_alerts_dev'

AZURE_ANTHROPIC_DEPLOYMENT=claude-sonnet-4-5
AZURE_ANTHROPIC_BASE_URL=<insert your Azure Anthropic base URL here>
AZURE_ANTHROPIC_API_KEY=<insert your Azure Anthropic API key here>
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-5

USE_AZURE=true

# Optional
DRY_RUN=false
BATCH_WORKERS=5
MAX_CONCURRENT_FETCHES=10
